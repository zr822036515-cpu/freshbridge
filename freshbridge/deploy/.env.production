# FreshBridge Production Environment Variables

# Server
PORT=8080
GIN_MODE=release

# Database (REQUIRED)
DB_DSN=root:changeme@tcp(127.0.0.1:3306)/freshbridge?charset=utf8mb4&parseTime=True
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_LIFETIME=600

# Redis (optional, for future session cache)
REDIS_ADDR=localhost:6379

# JWT (REQUIRED — generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-64-char-string
